#!/bin/bash
set -euo pipefail

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S.%N') $*"
}

cpu_mask=""
cpu_core_number=0
# Host path to the longhorn control directory (e.g. /var/lib/longhorn). When set,
# the script persists the SPDK cpu mask under this directory so that IRQ
# affinity changes survive crashes and can be reconciled on the next start.
longhorn_control_path=""
# Each flag independently gates one host-tuning mechanism that steers kernel
# work away from the SPDK CPUs. --enable-irq-affinity steers host IRQ
# smp_affinity; --enable-workqueue-affinity steers
# /sys/devices/virtual/workqueue/cpumask; --enable-rps steers Receive Packet
# Steering (rps_cpus) of the physical interfaces. Any combination may be enabled.
# When all are 0 (default), the script still reconciles stale state from a
# previous run (so toggling any off cleans up) but does NOT install any new
# tuning.
irq_affinity_enabled=0
workqueue_affinity_enabled=0
rps_enabled=0
host_mount_prefix="/host"
host_control_path=""
cpu_mask_file=""
host_proc_irq_dir="${host_mount_prefix}/proc/irq"
host_online_cpus_file="${host_mount_prefix}/sys/devices/system/cpu/online"
host_workqueue_dir="${host_mount_prefix}/sys/devices/virtual/workqueue"
host_workqueue_cpumask_file="${host_workqueue_dir}/cpumask"
host_net_dir="${host_mount_prefix}/sys/class/net"
instance_manager_options=()

# Compute a bitmask (as a hex "0x..." string) of all currently-online host CPUs
# by parsing /sys/devices/system/cpu/online. Handles arbitrary CPU id sets that
# are non-contiguous and/or do not start at 0 (e.g. "1-4", "0,2-3,5"). If the
# sysfs file cannot be read, falls back to a mask covering CPUs 0..nproc-1.
function get_online_cpu_mask() {
    if [ -r "$host_online_cpus_file" ]; then
        local range
        range=$(cat "$host_online_cpus_file")
        python3 -c "
import sys
s = sys.argv[1].strip()
mask = 0
for part in s.split(','):
    part = part.strip()
    if not part:
        continue
    if '-' in part:
        a, b = part.split('-', 1)
        a, b = int(a), int(b)
        if a > b:
            sys.exit('ERROR: invalid CPU range: ' + part)
        for i in range(a, b + 1):
            mask |= (1 << i)
    else:
        mask |= (1 << int(part))
if mask == 0:
    sys.exit('ERROR: parsed empty online CPU set from: ' + repr(sys.argv[1]))
print('0x{:x}'.format(mask))
" "$range"
    else
        local n
        n=$(nproc)
        python3 -c "print('0x{:x}'.format((1 << ${n}) - 1))"
    fi
}

# Convert an integer (decimal or 0x hex) into the comma-separated 32-bit hex
# group format expected by /proc/irq/*/smp_affinity (e.g. ffffffff,ffffffff).
function format_affinity_mask() {
    python3 -c "
import sys
m = int(sys.argv[1], 0)
if m == 0:
    print('0')
    sys.exit(0)
groups = []
while m > 0:
    groups.append('{:08x}'.format(m & 0xffffffff))
    m >>= 32
print(','.join(reversed(groups)))
" "$1"
}

# Write the given Linux-formatted affinity mask to default_smp_affinity and to
# every per-IRQ smp_affinity file. Per-IRQ failures are tolerated because the
# kernel forbids reassigning some IRQs (e.g. percpu/managed); a failure to write
# the default mask is treated as fatal.
function apply_irq_affinity() {
    local linux_mask="$1"

    if [ ! -d "$host_proc_irq_dir" ]; then
        log "ERROR: $host_proc_irq_dir is not available; cannot manage IRQ affinity"
        return 1
    fi

    if [ -w "${host_proc_irq_dir}/default_smp_affinity" ]; then
        if ! echo "$linux_mask" > "${host_proc_irq_dir}/default_smp_affinity"; then
            log "ERROR: Failed to write default_smp_affinity"
            return 1
        fi
    else
        log "ERROR: ${host_proc_irq_dir}/default_smp_affinity is not writable"
        return 1
    fi

    local updated=0
    local skipped=0
    local d irq target
    for d in "${host_proc_irq_dir}"/[0-9]*; do
        [ -d "$d" ] || continue
        target="${d}/smp_affinity"
        [ -w "$target" ] || { skipped=$((skipped + 1)); continue; }
        irq=$(basename "$d")
        if echo "$linux_mask" > "$target" 2>/dev/null; then
            updated=$((updated + 1))
        else
            skipped=$((skipped + 1))
        fi
    done
    log "Applied IRQ affinity mask ${linux_mask}: ${updated} IRQs updated, ${skipped} IRQs skipped"
    return 0
}

# Restore IRQ affinity to "all online CPUs", i.e. remove any restriction we may
# have installed for spdk_tgt on a previous run.
function clear_irq_affinity() {
    local online_mask_hex
    online_mask_hex=$(get_online_cpu_mask) || return 1
    if ! [[ "$online_mask_hex" =~ ^0x[0-9a-fA-F]+$ ]] || [ "$online_mask_hex" = "0x0" ]; then
        log "ERROR: Unable to determine online CPU mask (got: $online_mask_hex)"
        return 1
    fi
    local linux_mask
    linux_mask=$(format_affinity_mask "$online_mask_hex")
    log "Clearing IRQ affinity: restoring all online CPUs (online_mask=${online_mask_hex}, mask=${linux_mask})"
    apply_irq_affinity "$linux_mask"
}

# Restrict IRQs to the CPUs that are NOT used by spdk_tgt.
function set_irq_affinity_for_spdk_mask() {
    local spdk_mask_hex="$1"
    local online_mask_hex
    online_mask_hex=$(get_online_cpu_mask) || return 1
    if ! [[ "$online_mask_hex" =~ ^0x[0-9a-fA-F]+$ ]] || [ "$online_mask_hex" = "0x0" ]; then
        log "ERROR: Unable to determine online CPU mask (got: $online_mask_hex)"
        return 1
    fi
    local inv_mask_int
    inv_mask_int=$(python3 -c "
online = int('${online_mask_hex}', 0)
spdk = int('${spdk_mask_hex}', 0)
print(online & ~spdk)
")
    # inv_mask_int may exceed 64 bits, so use string comparison rather than -eq.
    if [ "$inv_mask_int" = "0" ]; then
        log "ERROR: SPDK cpu mask ${spdk_mask_hex} covers every online CPU (online_mask=${online_mask_hex}); refusing to set IRQ affinity to an empty set"
        return 1
    fi
    local linux_mask
    linux_mask=$(format_affinity_mask "$inv_mask_int")
    log "Setting IRQ affinity to exclude SPDK CPUs (spdk_mask=${spdk_mask_hex}, online_mask=${online_mask_hex}, irq_mask=${linux_mask})"
    apply_irq_affinity "$linux_mask"
}

# Write the given Linux-formatted affinity mask to the workqueue cpumask, and
# also propagate it to every per-workqueue cpumask under
# /sys/devices/virtual/workqueue/<name>/cpumask.
#
# The global cpumask is only the *default* for newly-created unbound
# workqueues and the *ceiling* for per-workqueue cpumasks; existing
# per-workqueue cpumasks are not visibly shrunk when the global mask is
# narrowed, so operators (and any code that reads the per-wq file) may still
# see workers permitted on the SPDK CPUs. Write the same mask to each
# per-workqueue cpumask so the runtime state matches the intent.
#
# The global write is strict-fatal (single well-known file). Per-workqueue
# writes are best-effort: some workqueues expose a read-only cpumask or
# reject writes for kernel reasons; those are counted as skipped, not fatal.
function apply_workqueue_affinity() {
    local linux_mask="$1"

    if [ ! -e "$host_workqueue_cpumask_file" ]; then
        log "ERROR: $host_workqueue_cpumask_file is not available; cannot manage workqueue cpumask"
        return 1
    fi
    if [ ! -w "$host_workqueue_cpumask_file" ]; then
        log "ERROR: $host_workqueue_cpumask_file is not writable"
        return 1
    fi
    if ! echo "$linux_mask" > "$host_workqueue_cpumask_file"; then
        log "ERROR: Failed to write workqueue cpumask (${linux_mask}) to $host_workqueue_cpumask_file"
        return 1
    fi
    log "Applied global workqueue cpumask ${linux_mask}"

    local updated=0
    local skipped=0
    local wq f
    for wq in "${host_workqueue_dir}"/*/; do
        [ -d "$wq" ] || continue
        f="${wq}cpumask"
        [ -f "$f" ] || continue
        [ -w "$f" ] || { skipped=$((skipped + 1)); continue; }
        if echo "$linux_mask" > "$f" 2>/dev/null; then
            updated=$((updated + 1))
        else
            skipped=$((skipped + 1))
        fi
    done
    log "Applied per-workqueue cpumask ${linux_mask}: ${updated} workqueues updated, ${skipped} workqueues skipped"
    return 0
}

# Restore the workqueue cpumask to "all online CPUs". If the sysfs file is not
# present (older kernels), this is treated as a no-op so reconcile stays
# best-effort — reconcile does not know which mechanism the previous run had
# enabled, so it optimistically tries both.
function clear_workqueue_affinity() {
    if [ ! -e "$host_workqueue_cpumask_file" ]; then
        log "Workqueue cpumask file $host_workqueue_cpumask_file not present; skipping workqueue clear"
        return 0
    fi
    local online_mask_hex
    online_mask_hex=$(get_online_cpu_mask) || return 1
    if ! [[ "$online_mask_hex" =~ ^0x[0-9a-fA-F]+$ ]] || [ "$online_mask_hex" = "0x0" ]; then
        log "ERROR: Unable to determine online CPU mask (got: $online_mask_hex)"
        return 1
    fi
    local linux_mask
    linux_mask=$(format_affinity_mask "$online_mask_hex")
    log "Clearing workqueue cpumask: restoring all online CPUs (online_mask=${online_mask_hex}, mask=${linux_mask})"
    apply_workqueue_affinity "$linux_mask"
}

# Restrict unbound kernel workqueues to the CPUs that are NOT used by spdk_tgt.
function set_workqueue_affinity_for_spdk_mask() {
    local spdk_mask_hex="$1"
    local online_mask_hex
    online_mask_hex=$(get_online_cpu_mask) || return 1
    if ! [[ "$online_mask_hex" =~ ^0x[0-9a-fA-F]+$ ]] || [ "$online_mask_hex" = "0x0" ]; then
        log "ERROR: Unable to determine online CPU mask (got: $online_mask_hex)"
        return 1
    fi
    local inv_mask_int
    inv_mask_int=$(python3 -c "
online = int('${online_mask_hex}', 0)
spdk = int('${spdk_mask_hex}', 0)
print(online & ~spdk)
")
    # inv_mask_int may exceed 64 bits, so use string comparison rather than -eq.
    if [ "$inv_mask_int" = "0" ]; then
        log "ERROR: SPDK cpu mask ${spdk_mask_hex} covers every online CPU (online_mask=${online_mask_hex}); refusing to set workqueue cpumask to an empty set"
        return 1
    fi
    local linux_mask
    linux_mask=$(format_affinity_mask "$inv_mask_int")
    log "Setting workqueue cpumask to exclude SPDK CPUs (spdk_mask=${spdk_mask_hex}, online_mask=${online_mask_hex}, wq_mask=${linux_mask})"
    apply_workqueue_affinity "$linux_mask"
}

# List the physical (non-virtual) network interfaces on the host. Interfaces
# whose /sys/class/net symlink resolves under devices/virtual (lo, bridges,
# veth, cni, ...) are skipped.
function list_physical_interfaces() {
    local path target
    for path in "${host_net_dir}"/*; do
        [ -L "$path" ] || continue
        target=$(readlink "$path" 2>/dev/null || true)
        case "$target" in
            *virtual*) continue ;;
        esac
        basename "$path"
    done
}

# Write the given Linux-formatted mask to rps_cpus of every rx queue of every
# physical interface. Per-queue failures are tolerated (counted, not fatal),
# because some queues may expose a read-only rps_cpus.
function apply_rps() {
    local linux_mask="$1"

    if [ ! -d "$host_net_dir" ]; then
        log "ERROR: $host_net_dir is not available; cannot manage RPS"
        return 1
    fi

    local ifaces
    ifaces=$(list_physical_interfaces)
    if [ -z "$ifaces" ]; then
        log "No physical interfaces found; skipping RPS"
        return 0
    fi

    local updated=0 skipped=0 ifname q
    for ifname in $ifaces; do
        for q in "${host_net_dir}/${ifname}"/queues/rx-*/rps_cpus; do
            [ -e "$q" ] || continue
            [ -w "$q" ] || { skipped=$((skipped + 1)); continue; }
            if echo "$linux_mask" > "$q" 2>/dev/null; then
                updated=$((updated + 1))
            else
                skipped=$((skipped + 1))
            fi
        done
    done
    log "Applied RPS mask ${linux_mask} on interfaces [${ifaces//$'\n'/ }]: ${updated} queues updated, ${skipped} skipped"
    return 0
}

# Restore RPS to "all online CPUs", i.e. remove any restriction we may have
# installed for spdk_tgt on a previous run.
function clear_rps() {
    local online_mask_hex
    online_mask_hex=$(get_online_cpu_mask) || return 1
    if ! [[ "$online_mask_hex" =~ ^0x[0-9a-fA-F]+$ ]] || [ "$online_mask_hex" = "0x0" ]; then
        log "ERROR: Unable to determine online CPU mask (got: $online_mask_hex)"
        return 1
    fi
    local linux_mask
    linux_mask=$(format_affinity_mask "$online_mask_hex")
    log "Clearing RPS: restoring all online CPUs (online_mask=${online_mask_hex}, mask=${linux_mask})"
    apply_rps "$linux_mask"
}

# Restrict RPS to the CPUs that are NOT used by spdk_tgt.
function set_rps_for_spdk_mask() {
    local spdk_mask_hex="$1"
    local online_mask_hex
    online_mask_hex=$(get_online_cpu_mask) || return 1
    if ! [[ "$online_mask_hex" =~ ^0x[0-9a-fA-F]+$ ]] || [ "$online_mask_hex" = "0x0" ]; then
        log "ERROR: Unable to determine online CPU mask (got: $online_mask_hex)"
        return 1
    fi
    local inv_mask_int
    inv_mask_int=$(python3 -c "
online = int('${online_mask_hex}', 0)
spdk = int('${spdk_mask_hex}', 0)
print(online & ~spdk)
")
    # inv_mask_int may exceed 64 bits, so use string comparison rather than -eq.
    if [ "$inv_mask_int" = "0" ]; then
        log "ERROR: SPDK cpu mask ${spdk_mask_hex} covers every online CPU (online_mask=${online_mask_hex}); refusing to set RPS to an empty set"
        return 1
    fi
    local linux_mask
    linux_mask=$(format_affinity_mask "$inv_mask_int")
    log "Setting RPS to exclude SPDK CPUs (spdk_mask=${spdk_mask_hex}, online_mask=${online_mask_hex}, rps_mask=${linux_mask})"
    apply_rps "$linux_mask"
}

# Orchestrator: apply whichever of IRQ / workqueue / RPS tuning are enabled. If
# all flags are 0 the caller should not have invoked us; we still short-circuit
# to a no-op for safety.
function apply_cpu_isolation_for_spdk_mask() {
    local spdk_mask_hex="$1"
    if [ "$irq_affinity_enabled" -eq 1 ]; then
        set_irq_affinity_for_spdk_mask "$spdk_mask_hex" || return 1
    fi
    if [ "$workqueue_affinity_enabled" -eq 1 ]; then
        set_workqueue_affinity_for_spdk_mask "$spdk_mask_hex" || return 1
    fi
    if [ "$rps_enabled" -eq 1 ]; then
        set_rps_for_spdk_mask "$spdk_mask_hex" || return 1
    fi
}

# Orchestrator: undo any IRQ / workqueue / RPS tuning we may have installed.
# Always attempts all of them because the on-disk marker (cpu_mask_file) does not
# record which mechanism was active last time; individual clears tolerate
# "nothing to do". A failure in one clear must NOT prevent the others from
# running, otherwise a transient failure in one would leave a stale restriction
# from another in place across the whole node.
function clear_cpu_isolation() {
    local rc=0
    clear_irq_affinity       || rc=1
    clear_workqueue_affinity || rc=1
    clear_rps                || rc=1
    return "$rc"
}

# Handle leftover state from a previous (possibly crashed) instance-manager run.
# If we previously persisted a cpu_mask, the host IRQ / workqueue affinity may
# still be restricted to non-SPDK CPUs; clear it before we (potentially) compute
# a new mask so the system is in a known state.
function reconcile_previous_cpu_mask_file() {
    [ -n "$cpu_mask_file" ] || return 0
    [ -f "$cpu_mask_file" ] || return 0

    local previous_mask
    previous_mask=$(tr -d '[:space:]' < "$cpu_mask_file" || true)
    log "Found leftover SPDK cpu_mask file at ${cpu_mask_file} (previous mask: ${previous_mask:-<empty>}); clearing stale IRQ / workqueue affinity"
    if ! clear_cpu_isolation; then
        log "ERROR: Failed to clear stale CPU isolation state"
        return 1
    fi
    rm -f "$cpu_mask_file"
}

# Persist the cpu_mask used by spdk_tgt and program the matching IRQ and
# workqueue affinity so host kernel work is steered away from SPDK CPUs.
function persist_cpu_mask_and_apply_cpu_isolation() {
    [ -n "$cpu_mask_file" ] || return 0
    if [ -z "$cpu_mask" ]; then
        log "ERROR: cpu_mask is empty; cannot persist or apply CPU isolation"
        return 1
    fi

    mkdir -p "$(dirname "$cpu_mask_file")"
    local tmp="${cpu_mask_file}.tmp"
    if ! printf '%s\n' "$cpu_mask" > "$tmp"; then
        log "ERROR: Failed to write ${tmp}"
        return 1
    fi
    if ! mv -f "$tmp" "$cpu_mask_file"; then
        log "ERROR: Failed to move ${tmp} to ${cpu_mask_file}"
        rm -f "$tmp"
        return 1
    fi
    log "Persisted SPDK cpu mask ${cpu_mask} to ${cpu_mask_file}"

    if ! apply_cpu_isolation_for_spdk_mask "$cpu_mask"; then
        log "ERROR: Failed to apply CPU isolation for SPDK cpu mask ${cpu_mask}"
        return 1
    fi
}

# The caller will validate the input arguments and set the cpu_mask or cpu_core_number accordingly.
# The cpu_mask will be an empty string when the cpu_core_number is set, and vice versa.
function start_spdk_tgt() {
    if [ -n "$cpu_core_number" ] && [ "$cpu_core_number" -gt 0 ] && [ -z "$cpu_mask" ]; then
        log "Starting get pinned CPU set..."
        # 1. Get the pinned CPU string from cgroup
        if [ -f /host/sys/fs/cgroup/cgroup.controllers ]; then
            # cgroup v2
            cgroup_path=$(awk -F: '$1=="0" {print $3}' /proc/self/cgroup)
            cpu_set=$(cat "/host/sys/fs/cgroup${cgroup_path}/cpuset.cpus.effective" 2>/dev/null || \
                      cat "/host/sys/fs/cgroup${cgroup_path}/cpuset.cpus" 2>/dev/null)
        else
            # cgroup v1
            cgroup_path=$(awk -F: '$2~/cpuset/ {print $3}' /proc/self/cgroup)
            cpu_set=$(cat "/host/sys/fs/cgroup/cpuset${cgroup_path}/cpuset.cpus" 2>/dev/null)
        fi
        if [ -z "$cpu_set" ]; then
            log "ERROR: Failed to read cpuset from cgroup. Exiting."
            exit 1
        fi
        log "Pinned CPUs are: $cpu_set"
        # 2. Collect CPU IDs limited to cpu_core_number CPUs
        cpu_ids=()
        count=0
        for i in $(echo "$cpu_set" | tr ',' ' '); do
            if [ "$count" -ge "$cpu_core_number" ]; then
                break
            fi
            if [[ "$i" == *-* ]]; then
                start=$(echo "$i" | cut -d'-' -f1)
                range_end=$(echo "$i" | cut -d'-' -f2)
                if [[ "$range_end" == *:* ]]; then
                    step=$(echo "$range_end" | cut -d':' -f2)
                    end=$(echo "$range_end" | cut -d':' -f1)
                else
                    end=$range_end
                    step=1
                fi
                start=$((start))
                end=$((end))
                step=$((step))
                if [ "$step" -le 0 ]; then
                    log "ERROR: Invalid cpuset stride in '$i'"
                    exit 1
                fi
                if [ "$start" -gt "$end" ]; then
                    log "ERROR: Invalid cpuset range '$i': start > end"
                    exit 1
                fi
                for ((j=start; j<=end; j+=step)); do
                    if [ "$count" -ge "$cpu_core_number" ]; then
                        break
                    fi
                    cpu_ids+=("$j")
                    count=$((count + 1))
                done
            else
                cpu_id=$((i))
                cpu_ids+=("$cpu_id")
                count=$((count + 1))
            fi
        done
        # 3. Calculate hex bitmask supporting CPU IDs >= 64
        cpu_mask=$(python3 -c "
import sys
ids = [int(x) for x in sys.argv[1:]]
mask = 0
for i in ids:
    mask |= (1 << i)
print('0x{:x}'.format(mask))
" "${cpu_ids[@]}")
        log "Calculated CPU Mask: $cpu_mask"
    fi
    # Persist the cpu mask (so a crashed run can be reconciled) and, if any
    # isolation mechanism is enabled, steer host IRQs and/or unbound kernel
    # workqueues away from the SPDK CPUs before launching spdk_tgt. When both
    # flags are disabled, this is a no-op.
    if [ "$irq_affinity_enabled" -eq 1 ] || [ "$workqueue_affinity_enabled" -eq 1 ] || [ "$rps_enabled" -eq 1 ]; then
        if ! persist_cpu_mask_and_apply_cpu_isolation; then
            log "ERROR: Aborting spdk_tgt start because CPU isolation preparation failed"
            exit 1
        fi
    fi
    # 4. Execute the main process replacing the shell
    exec instance-manager "${instance_manager_options[@]}" --spdk-cpumask "$cpu_mask"
}
while [[ $# -gt 0 ]]; do
    opt="$1"
    case $opt in
        -m|--spdk-cpumask)
            if [[ $# -lt 2 ]]; then
                log "ERROR: --spdk-cpumask requires a value"
                exit 1
            fi
            cpu_mask="$2"
            shift
            ;;
        -c|--spdk-core-number)
            if [[ $# -lt 2 ]]; then
                log "ERROR: --spdk-core-number requires a value"
                exit 1
            fi
            cpu_core_number="$2"
            if ! [[ "$cpu_core_number" =~ ^[0-9]+$ ]]; then
                log "ERROR: --spdk-core-number must be a non-negative integer, got: $cpu_core_number"
                exit 1
            fi
            shift
            ;;
        --longhorn-control-path)
            if [[ $# -lt 2 ]]; then
                log "ERROR: --longhorn-control-path requires a value"
                exit 1
            fi
            longhorn_control_path="$2"
            if [[ "$longhorn_control_path" != /* ]]; then
                log "ERROR: --longhorn-control-path must be an absolute host path, got: $longhorn_control_path"
                exit 1
            fi
            shift
            ;;
        --enable-irq-affinity)
            irq_affinity_enabled=1
            ;;
        --enable-workqueue-affinity)
            workqueue_affinity_enabled=1
            ;;
        --enable-rps)
            rps_enabled=1
            ;;
        *)
            instance_manager_options+=("$1")
            ;;
    esac
    shift
done

if [ -n "$longhorn_control_path" ]; then
    host_control_path="${host_mount_prefix}${longhorn_control_path}"
    # Keep state under a dedicated subdirectory so it does not collide with
    # user data, replica files, etc. under the longhorn control path.
    cpu_mask_file="${host_control_path}/instance-manager/v2/spdk_cpu_mask"
    log "Using longhorn control path: ${longhorn_control_path} (cpu_mask file in-container: ${cpu_mask_file})"
    if ! reconcile_previous_cpu_mask_file; then
        log "ERROR: Failed to reconcile previous cpu_mask state; aborting"
        exit 1
    fi
fi

start_spdk_tgt